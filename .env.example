# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Supabase — https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role — server-only; never expose to the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — required for POST /api/agent (Claude)
ANTHROPIC_API_KEY=

# Hostaway PMS — only needed if you use Hostaway-backed features
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_CLIENT_SECRET=

# Slack — required for POST /api/slack/events (the @-mention bot).
# Create an app at https://api.slack.com/apps with these settings:
#   Bot scopes: app_mentions:read, chat:write, users:read, users:read.email
#   Subscribed bot events: app_mention
#   Event Subscriptions Request URL: https://<your-domain>/api/slack/events
# Then install the app to your workspace.
#
# SLACK_BOT_TOKEN — "Bot User OAuth Token" from OAuth & Permissions (xoxb-...)
SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET — "Signing Secret" from Basic Information → App Credentials
SLACK_SIGNING_SECRET=
# Optional: comma-separated list of Slack channel ids to allow. Empty = allow all.
# SLACK_ALLOWED_CHANNELS=C0123456789,C0987654321
SLACK_ALLOWED_CHANNELS=
