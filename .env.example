# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Supabase — https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role — server-only; never expose to the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — required for POST /api/agent (Claude)
ANTHROPIC_API_KEY=

# App base URL — used by the agent to build absolute task links in replies
# (e.g. https://app.foreshadow.com). REQUIRED for Slack: Slack only renders
# absolute http(s) URLs. The in-app chat falls back gracefully when unset
# (it navigates via the relative path), so this is effectively a Slack-only
# requirement, but keep it set in every environment for consistency.
# No trailing slash.
APP_BASE_URL=

# Hostaway PMS — only needed if you use Hostaway-backed features
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_CLIENT_SECRET=

# Slack — required for POST /api/slack/events (the bot's @-mention + DM surface).
# Create an app at https://api.slack.com/apps with these settings:
#   Bot scopes:        app_mentions:read, chat:write, users:read,
#                      users:read.email, im:history, im:read, im:write
#   Subscribed events: app_mention, message.im
#   App Home tab:      enable "Allow users to send Slash commands and
#                      messages from the messages tab" (so DMs work)
#   Event Subscriptions Request URL: https://<your-domain>/api/slack/events
# Then install the app to your workspace.
#
# SLACK_BOT_TOKEN — "Bot User OAuth Token" from OAuth & Permissions (xoxb-...)
SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET — "Signing Secret" from Basic Information → App Credentials
SLACK_SIGNING_SECRET=
# Optional: comma-separated list of Slack channel ids to allow @-mentions from.
# Empty = allow all channels. DMs are NOT filtered by this list (they're 1:1
# and the user already proved access by being in your workspace).
# SLACK_ALLOWED_CHANNELS=C0123456789,C0987654321
SLACK_ALLOWED_CHANNELS=
