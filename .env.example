# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Supabase — https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role — server-only; never expose to the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — required for POST /api/agent (Claude)
ANTHROPIC_API_KEY=

# Hostaway PMS — only needed if you use Hostaway-backed features
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_CLIENT_SECRET=
